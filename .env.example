# OpenClaw Folder Path Configuration
# Specify the full path to your OpenClaw folder here
# Examples:
#   - macOS/Linux: /home/user/.openclaw or /Users/user/.openclaw or ~/.openclaw
#   - Windows: C:\Users\user\.openclaw or C:\OpenClaw

# Leave empty to use the relative path resolution (if running from tools/mc within OpenClaw)
# OPENCLAW_PATH=
